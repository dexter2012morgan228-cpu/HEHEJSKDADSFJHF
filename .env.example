# Required
DISCORD_TOKEN=replace-with-your-bot-token

# Optional — your Discord user ID (preferred way to resolve owner)
OWNER_ID=
OWNER_USERNAME=jadexov

# Optional — channel where bot pins its runtime config (a private admin channel)
CONFIG_CHANNEL_ID=

# Optional — log channel for events (new requests / decisions / blocks)
LOG_CHANNEL_ID=

# Optional — role granted to applicants on Accept
ROLE_ON_ACCEPT_ID=

# Anti-abuse defaults (overridable via /invconfig at runtime)
COOLDOWN_HOURS=12
MIN_ACCOUNT_AGE_DAYS=7

# Used to sign generated access keys; on Render set this to a random secret
KEY_SIGNING_SECRET=change-me

# Health server port (Render sets PORT automatically)
PORT=8080
